# AI Skill Gateway - Environment Configuration

# Application
APP_NAME="AI Skill Gateway"
APP_VERSION="1.0.0"
APP_HOST=127.0.0.1
APP_PORT=8080
DEBUG=false

# AI Configuration
# AI_EMBEDDING_* are the Quarkus config-mapped properties (ai.embedding.url / ai.embedding.model)
# EMBEDDING_MODEL is a legacy key from the FastAPI prototype - prefer AI_EMBEDDING_MODEL
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
AI_EMBEDDING_URL=http://localhost:11434/api/embeddings
AI_EMBEDDING_MODEL=nomic-embed-text

# Vector Database
VECTOR_DB_PATH=./data/vector_db
VECTOR_DB_COLLECTION=skills

# Storage - Local
LOCAL_STORAGE_PATH=C:/Skills
LOCAL_STORAGE_RECURSIVE=true

# Storage - PostgreSQL (Optional)
# POSTGRES_* used by Docker Compose to spin up the DB container
# DB_* used by Quarkus JDBC (quarkus.datasource.*) - keep values in sync with POSTGRES_*
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=skills
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_ENABLED=false
DB_USERNAME=admin
DB_PASSWORD=changeme
DB_JDBC_URL=jdbc:postgresql://localhost:5432/skillgateway

# Storage - Google Drive (Optional)
GDRIVE_ENABLED=false
GDRIVE_CREDENTIALS_PATH=./config/gdrive-credentials.json
GDRIVE_FOLDER_ID=

# Memory
MEMORY_ENABLED=true
MEMORY_MAX_HISTORY=10
MEMORY_SIMILARITY_THRESHOLD=0.85

# Authentication
AUTH_API_KEY=your_api_key_here

# Logging
LOG_LEVEL=INFO
LOG_PATH=./data/logs/gateway.log
